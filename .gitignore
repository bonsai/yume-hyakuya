```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Database
*.db

# Dependencies
.venv/
venv/
env/
.env
.env.local
.env.*

# Logs and temp files
*.log
*.tmp
*.swp

# Editors
.vscode/
.idea/
*.swo
*.swn

# Build artifacts
build/
dist/
target/
*.o
*.obj
*.so
*.dll
*.exe

# Coverage
.coverage
coverage/
htmlcov/

# Testing
.pytest_cache/
.mypy_cache/
```