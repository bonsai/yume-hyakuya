{
  "version": 2,
  "builds": [
    { "src": "templates/**", "use": "@vercel/static" },
    { "src": "static/**", "use": "@vercel/static" },
    { "src": "flow.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/flow.html" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/static/(.*)", "dest": "/static/$1" }
  ]
}
